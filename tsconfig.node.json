{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "lib": ["es2020"],
        "types": ["node"],
        "ignoreDeprecations": "6.0",
        "moduleResolution": "node",
        "strict": false,
        "declaration": true,      // genera .d.ts
        "declarationMap": true   // útil para debugging
    },
    "include": [
        "src/**/*.ts",
        "test/**/*.ts"
    ]
}
