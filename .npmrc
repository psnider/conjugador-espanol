# --- Prevención de ataques ---
ignore-scripts=true          # Bloquea scripts lifecycle maliciosos (preinstall, postinstall)
save-exact=true              # Pinned versions: instala "^1.2.3" como "1.2.3"
engine-strict=true           # Exige la versión exacta de Node.js

# --- Integridad ---
package-lock=true            # Fuerza uso de package-lock.json
lockfile-version=3           # Usa la versión más reciente del formato

# --- Auditoría ---
audit-level=moderate         # Nivel mínimo para alertar (opcional)

# --- Registro seguro ---
registry=https://registry.npmjs.org/  # Solo el oficial, nada de registros custom
