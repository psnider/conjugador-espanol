{
  "name": "conjugador-espanol",
  "version": "1.0",
  "description": "conjugador de verbos españoles usando reglas lingüisticas",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "tsc --sourceMap --outDir generated",
    "gen-web-page": "node generated/html/combine-code-into-template.js",
    "validate": "node generated/test/validate-stem-change-patterns.js && node generated/test/validate-verbs-list.js",
    "test-full": "npm run validate && npm run test",
    "test-list": "node generated/test/test.js",
    "test": "node generated/test/test-verbs-using-saved-conjugations.js",
    "test-conjugate-verb": "node generated/test/test-conjugate-verb.js",
    "update-verbos-with-test-results": "node generated/test/update-verbos-with-test-results.js",
    "insert-verbs-into-verbs-list": "node generated/test/insert-verbs-into-verbs-list.js",
    "clean": "rm -rf generated",
    "prep-release": "npm run clean && npm run build && npm run validate && npm run test && npm run update-verbos-with-test-results && npm run gen-web-page"
  },
  "author": "Peter Snider",
  "license": "CC-BY-NC-4.0",
  "devDependencies": {
    "@types/node": "^20.3.3",
    "typescript": "^5.9.3"
  }
}